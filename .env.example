# Database connection string for PostgreSQL running in docker-compose.
#
# Note the port: 5433, not 5432. A locally-installed PostgreSQL commonly already
# listens on 5432 and silently shadows the container — connections then land in
# the wrong database and fail to authenticate. Keep these in step: POSTGRES_PORT
# is the host port docker-compose publishes, and DATABASE_URL must point at it.
DATABASE_URL=postgresql://mandate:mandate@localhost:5433/mandate

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=mandate
POSTGRES_PASSWORD=mandate
POSTGRES_DB=mandate
POSTGRES_PORT=5433

# IBM watsonx.ai credentials for Granite LLM
WATSONX_API_KEY=your_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
